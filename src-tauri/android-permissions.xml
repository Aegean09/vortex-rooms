<!--
  Android permissions required for Vortex Rooms.
  After running `npx tauri android init`, merge these into:
    src-tauri/gen/android/app/src/main/AndroidManifest.xml

  These permissions are needed for WebRTC voice/video chat and audio processing.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- WebRTC audio/video -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Network (WebRTC, Firebase) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Keep voice call alive when screen off -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Vibration for notifications -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Hardware feature declarations (not required, graceful degrade) -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="true" />
</manifest>
