{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vortex",
  "version": "0.6.8",
  "identifier": "com.vortex.rooms",
  "build": {
    "frontendDist": "https://vortex-rooms.com",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vortex",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/android/mipmap-hdpi/ic_launcher.png",
      "icons/android/mipmap-mdpi/ic_launcher.png",
      "icons/android/mipmap-xhdpi/ic_launcher.png",
      "icons/android/mipmap-xxhdpi/ic_launcher.png",
      "icons/android/mipmap-xxxhdpi/ic_launcher.png"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Real-time voice and text chat",
    "longDescription": "Vortex - Ephemeral voice and text chat rooms powered by WebRTC"
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "host": "vortex-rooms.com",
          "pathPrefix": ["/session"]
        }
      ],
      "desktop": {
        "schemes": ["vortex"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/Aegean09/vortex-rooms/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZERTI3RjMxRThDRkIzQTIKUldTaXM4L29NWC9pYlQzQSt3a1FMbEpUQnZnaDlWdTd0NWFqb1JtU1ZxQ0dNWERMcHFkQlR0cjAK"
    }
  }
}
