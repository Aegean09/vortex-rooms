NEXT_PUBLIC_FIREBASE_PROJECT_ID=XXX
NEXT_PUBLIC_FIREBASE_APP_ID=XXX
NEXT_PUBLIC_FIREBASE_API_KEY=XXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=XXX
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=XXX
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=XXX

# TURN server (optional - enables relay fallback for strict NAT/firewalls)
# Without TURN, peers behind symmetric NAT cannot connect.
# Use Metered.ca, Xirsys, or self-hosted coturn.
NEXT_PUBLIC_TURN_URL=turn:your-turn-server.com:3478
NEXT_PUBLIC_TURN_USERNAME=vortex
NEXT_PUBLIC_TURN_CREDENTIAL=your-credential

# Firebase Admin SDK (optional - for server-side session cleanup)
# Get this from Firebase Console > Project Settings > Service Accounts > Generate new private key
# Then stringify the JSON: JSON.stringify(require('./serviceAccountKey.json'))
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}